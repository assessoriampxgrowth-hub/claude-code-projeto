# ─── Banco de dados (Neon Postgres via Vercel Marketplace) ────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ─── Autenticação admin ──────────────────────────────────────────
ADMIN_PASSWORD="sua-senha-segura-aqui"
JWT_SECRET="string-aleatoria-longa-aqui"

# ─── Criptografia de tokens Meta ──────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="64-caracteres-hex-aqui"

# ─── Cron ─────────────────────────────────────────────────────────
CRON_SECRET="string-aleatoria-para-proteger-cron"

# ─── Vercel Blob (já existente) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── URL do portal ───────────────────────────────────────────────
CLIENT_PORTAL_URL="https://seu-portal.vercel.app"

# ─── UazAPI (WhatsApp) ─────────────────────────────────────────────
WHATSAPP_API_URL="https://free.uazapi.com"
WHATSAPP_API_TOKEN="seu-token-de-instancia-aqui"
