# ─── Meta Marketing API ───────────────────────────────────────────
META_ACCESS_TOKEN=seu_access_token_aqui
META_AD_ACCOUNT_ID=act_000000000000000   # formato: act_ + número da conta

# ─── UazAPI (WhatsApp) ────────────────────────────────────────────
WHATSAPP_API_URL=https://free.uazapi.com
WHATSAPP_API_TOKEN=seu-token-de-instancia-aqui

# ─── Destinatários do relatório ───────────────────────────────────
# Números no formato internacional, separados por vírgula
WHATSAPP_RECIPIENTS=5511999999999,5511888888888

# ─── Agendamento ──────────────────────────────────────────────────
# Dia da semana: monday, tuesday, wednesday, thursday, friday, saturday, sunday
SCHEDULE_DAY=monday
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# ─── Período do relatório (em dias) ───────────────────────────────
REPORT_DAYS=7

# ─── Vercel Blob (portal do cliente) ──────────────────────────────
# Obtenha em: vercel.com → seu projeto → Storage → Blob → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxx

# URL do portal após deploy no Vercel (preencha depois do deploy)
CLIENT_PORTAL_URL=https://seu-portal.vercel.app
